rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is an authenticated admin.
    // For this app, we assume any authenticated user is an admin.
    function isAdmin() {
      return request.auth != null;
    }

    // Stores sensitive reporter information and internal notes.
    match /incidents/{incidentId} {
      // ALLOW server-side creation of new incidents.
      allow create;

      // ALLOW admins to read, update, and delete.
      allow read, update, delete: if isAdmin();
    }

    // Stores non-sensitive data for public display.
    match /public_incidents/{incidentId} {
      // ALLOW public read access for the public incidents page.
      allow read;
      
      // ALLOW server-side creation.
      allow create;

      // ALLOW admins to update status and notes.
      allow update, delete: if isAdmin();
    }
  }
}
