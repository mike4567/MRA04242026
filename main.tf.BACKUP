terraform {
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = ">= 5.0"
    }
    random = {
      source  = "hashicorp/random"
      version = ">= 3.0"
    }
  }
}

provider "google" {
  project = var.project_id
  region  = var.region
}

# ==============================================================================
# 1. ENABLE APIS
# ==============================================================================
resource "google_project_service" "apis" {
  for_each = toset([
    "run.googleapis.com",
    "sqladmin.googleapis.com", # Required for Cloud SQL
    "firestore.googleapis.com",
    "secretmanager.googleapis.com",
    "artifactregistry.googleapis.com",
    "cloudbuild.googleapis.com",
    "iam.googleapis.com",
    "aiplatform.googleapis.com" # Required for Vertex AI
  ])
  service            = each.key
  disable_on_destroy = false
}

# ==============================================================================
# 2. SECURITY IDENTITY (The "Janitor")
# ==============================================================================
resource "google_service_account" "app_sa" {
  account_id   = "mra-app-runner"
  display_name = "Marine Response App Runtime Identity"
  description  = "Identity used strictly by Cloud Run to access backing services."
  depends_on   = [google_project_service.apis]
}

# ==============================================================================
# 3. STORAGE (For Incident Photos)
# ==============================================================================
resource "google_storage_bucket" "media_bucket" {
  name          = "${var.project_id}-media-assets" # Unique bucket name
  location      = var.region
  force_destroy = false 

  uniform_bucket_level_access = true
  
  cors {
    origin          = ["*"]
    method          = ["GET", "HEAD", "PUT", "POST", "DELETE"]
    response_header = ["*"]
    max_age_seconds = 3600
  }
}

# ==============================================================================
# 4. DATABASE (Cloud SQL - Postgres)
# ==============================================================================
resource "random_id" "db_suffix" {
  byte_length = 4
}

resource "google_sql_database_instance" "main" {
  name             = "mra-db-${random_id.db_suffix.hex}"
  database_version = "POSTGRES_15"
  region           = var.region
  deletion_protection = false # Set to TRUE for production to prevent accidents

  settings {
    tier = "db-f1-micro" # Smallest tier for Dev/Test cost savings
    
    ip_configuration {
      ipv4_enabled = true 
    }
  }
  depends_on = [google_project_service.apis]
}

resource "google_sql_database" "database" {
  name     = "marine_response_db"
  instance = google_sql_database_instance.main.name
}

resource "google_sql_user" "db_user" {
  name     = "mra_app_user"
  instance = google_sql_database_instance.main.name
  password = var.db_password # Defined in variables.tf
}

# ==============================================================================
# 5. IAM BINDINGS (Least Privilege)
# ==============================================================================

# Allow App to connect to Cloud SQL
resource "google_project_iam_member" "sql_client" {
  project = var.project_id
  role    = "roles/cloudsql.client"
  member  = "serviceAccount:${google_service_account.app_sa.email}"
}

# Allow App to view/upload photos
resource "google_project_iam_member" "storage_admin" {
  bucket = google_storage_bucket.media_bucket.name
  role   = "roles/storage.objectAdmin"
  member = "serviceAccount:${google_service_account.app_sa.email}"
}

# Allow App to use Vertex AI (Gemini)
resource "google_project_iam_member" "vertex_user" {
  project = var.project_id
  role    = "roles/aiplatform.user"
  member  = "serviceAccount:${google_service_account.app_sa.email}"
}

# ==============================================================================
# 6. CLOUD RUN (The Application)
# ==============================================================================
resource "google_cloud_run_service" "app" {
  name     = "marine-response-app"
  location = var.region

  template {
    spec {
      service_account_name = google_service_account.app_sa.email
      timeout_seconds      = 300
      
      containers {
        image = var.container_image
        
        # --- Environment Variables ---
        
        # 1. System Config
        env {
            name = "GCS_BUCKET_NAME"
            value = google_storage_bucket.media_bucket.name
        }
        env {
            name = "GOOGLE_CLOUD_PROJECT"
            value = var.project_id
        }

        # 2. Database Connection (Auto-constructed)
        # This builds the socket connection string automatically
        env {
            name = "DATABASE_URL"
            value = "postgres://mra_app_user:${var.db_password}@/marine_response_db?host=/cloudsql/${google_sql_database_instance.main.connection_name}"
        }

        # 3. API Keys & Secrets (Passed from variables)
        env {
            name = "GOOGLE_MAPS_API_KEY"
            value = var.google_maps_api_key
        }
        env {
            name = "GOOGLE_AI_API_KEY"
            value = var.google_ai_api_key
        }
        env {
            name = "TWILIO_ACCOUNT_SID"
            value = var.twilio_account_sid
        }
        env {
            name = "TWILIO_AUTH_TOKEN"
            value = var.twilio_auth_token
        }
        env {
            name = "TWILIO_MESSAGING_SERVICE_SID"
            value = var.twilio_messaging_service_sid
        }
        env {
            name = "TWILIO_PHONE_NUMBER"
            value = var.twilio_phone_number
        }
        env {
            name = "RESPONDER_PHONE_NUMBER"
            value = var.responder_phone_number
        }
        
        # 4. Firebase (Public config is fine in env vars)
        env {
             name = "NEXT_PUBLIC_FIREBASE_API_KEY"
             value = var.firebase_api_key
        }
        env {
            name = "FIREBASE_ADMIN_PRIVATE_KEY"
            value = var.firebase_admin_private_key
        }
      }
    }
    
    metadata {
      annotations = {
        # Automatically turn on the Cloud SQL Proxy sidecar
        "run.googleapis.com/cloudsql-instances" = google_sql_database_instance.main.connection_name
        "run.googleapis.com/client-name"        = "terraform"
      }
    }
  }

  traffic {
    percent         = 100
    latest_revision = true
  }
  
  depends_on = [google_project_service.apis, google_sql_database_instance.main]
}